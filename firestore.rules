rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar si el usuario es administrador
    function isAdmin() {
      return request.auth != null && 
             (request.auth.token.email.matches('(?i)admin@admin.com') || 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin');
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // --- PRODUCTOS ---
    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        request.auth != null && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']) &&
        request.resource.data.stock is int &&
        request.resource.data.stock >= 0
      );
    }

    // --- PEDIDOS ---
    match /orders/{orderId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && 
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.total is number &&
                      request.resource.data.estado in ['pendiente', 'pagado'];
      allow update: if isAdmin();
      allow delete: if false; // Los pedidos no se borran, se cancelan
    }

    // --- LOGS DE INVENTARIO ---
    match /inventory_logs/{logId} {
      allow read: if isAdmin();
      allow create: if request.auth != null && 
                      request.resource.data.change is int &&
                      request.resource.data.reason in ['sale', 'return', 'manual'];
    }

    // --- USUARIOS ---
    match /users/{userId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId && 
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /carts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /changeHistory/{historyId} {
      allow read: if isAdmin();
      allow create: if request.auth != null && isAdmin();
    }

    match /providers/{providerId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true; // Cualquiera puede leer la configuración (nombre tienda, etc.)
      allow write: if isAdmin(); // Solo admins pueden cambiar la configuración
    }
  }
}
