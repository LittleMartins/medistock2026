rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar si el usuario es administrador
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email.matches('(?i)admin@admin.com') || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // --- PRODUCTOS ---
    match /products/{productId} {
      allow read: if true;
      allow create, delete, update: if isAdmin();
    }

    // --- PEDIDOS ---
    match /orders/{orderId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && 
                      request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false; // Los pedidos no se borran, se cancelan
    }

    // --- LOGS DE INVENTARIO ---
    match /inventory_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }

    // --- USUARIOS ---
    match /users/{userId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /carts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /changeHistory/{historyId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }

    match /providers/{providerId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true; // Cualquiera puede leer la configuración (nombre tienda, etc.)
      allow write: if isAdmin(); // Solo admins pueden cambiar la configuración
    }
  }
}
